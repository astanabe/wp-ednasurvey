msgid "Server Environment"
msgstr "サーバー環境"

msgid "Status"
msgstr "状態"

msgid "Component"
msgstr "コンポーネント"

msgid "Version"
msgstr "バージョン"

msgid "Details"
msgstr "詳細"

msgid "Items marked with a red X are required for core functionality. Items marked with a warning may limit certain features but the plugin will still operate."
msgstr "赤いXが付いた項目はプラグインの主要機能に必須です。警告マークの項目は一部の機能が制限されますが、プラグイン自体は動作します。"

#: includes/admin/class-admin-settings.php (environment checks)
msgid "PHP 8.1 or later is required."
msgstr "PHP 8.1以上が必要です。"

msgid "PHP 8.1 or later is required. Current version does not meet the requirement."
msgstr "PHP 8.1以上が必要です。現在のバージョンは要件を満たしていません。"

msgid "Not installed. CLI tools (heif-convert, ffmpeg, exiftool) will be used as fallback for HEIC/HEIF processing."
msgstr "未インストール。CLIツール（heif-convert, ffmpeg, exiftool）がHEIC/HEIF処理のフォールバックとして使用されます。"

msgid "Installed but HEIC format is not supported. CLI tools (heif-convert, ffmpeg, exiftool) will be used as fallback."
msgstr "インストール済みですがHEIC形式に非対応です。CLIツール（heif-convert, ffmpeg, exiftool）がフォールバックとして使用されます。"

msgid "HEIC/HEIF to JPEG conversion and GPS extraction from HEIC/HEIF photos are available."
msgstr "HEIC/HEIF写真のJPEG変換とGPSデータ取得が利用可能です。"

msgid "GPS data can be extracted from JPEG photo EXIF metadata."
msgstr "JPEG写真のEXIFメタデータからGPSデータを取得できます。"

msgid "Not installed. GPS data cannot be extracted from JPEG photos. Location must be entered manually."
msgstr "未インストール。JPEG写真からGPSデータを取得できません。位置情報は手動で入力する必要があります。"

msgid "Multi-byte string processing (Japanese text) is available."
msgstr "マルチバイト文字列処理（日本語テキスト）が利用可能です。"

msgid "Not installed. Japanese text processing may not work correctly."
msgstr "未インストール。日本語テキスト処理が正しく動作しない場合があります。"

msgid "Required by PhpSpreadsheet for Excel (.xlsx) file handling."
msgstr "PhpSpreadsheetによるExcel (.xlsx) ファイル処理に必要です。"

msgid "Not installed. Excel template generation and offline submission upload will not work."
msgstr "未インストール。Excelテンプレート生成とオフライン送信アップロードが動作しません。"

msgid "Excel template generation and offline data upload are available."
msgstr "Excelテンプレート生成とオフラインデータアップロードが利用可能です。"

msgid "Not installed. Run \"composer install\" in the plugin directory. Excel template and offline submission features will not work."
msgstr "未インストール。プラグインディレクトリで \"composer install\" を実行してください。Excelテンプレートとオフライン送信機能が動作しません。"

