msgstr "緯度"

msgid "Lng"
msgstr "経度"

msgid "Actions"
msgstr "操作"

msgid "Copy & Resubmit"
msgstr "コピーして再投稿"

msgid "Edit & Resubmit"
msgstr "修正して再投稿"

msgid "The original submission will remain as-is. Please ask the administrator via chat to delete the old submission."
msgstr "修正前の投稿も残ったままになります。管理者に以前の投稿を削除するようチャットで依頼して下さい。"

msgid "Back to Dashboard"
msgstr "ダッシュボードに戻る"

