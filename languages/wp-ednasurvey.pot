msgid "Only CSV/TSV files are accepted."
msgstr "CSV/TSVファイルのみ使用できます。"

#, php-format
msgid "%1$d users created, %2$d skipped (already exist)."
msgstr "%1$d名のユーザーを作成、%2$d名をスキップしました（既に存在）。"

msgid "Invalid data."
msgstr "無効なデータです。"

msgid "Custom fields saved."
msgstr "カスタムフィールドを保存しました。"

#: includes/services/class-user-import-service.php
msgid "Could not open file."
msgstr "ファイルを開けません。"

msgid "Empty file."
msgstr "空のファイルです。"

msgid "Missing \"email\" column."
msgstr "\"email\"カラムがありません。"

#: includes/services/class-notification-service.php
#, php-format
msgid "[%1$s] New message from %2$s"
msgstr "[%1$s] %2$sからの新しいメッセージ"

#, php-format
msgid "%1$s sent a new message:\n\n%2$s\n\nView and reply: %3$s"
msgstr "%1$sが新しいメッセージを送信しました:\n\n%2$s\n\n確認・返信: %3$s"

